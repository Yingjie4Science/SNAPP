# Secrets — never commit real credentials
.env

# Data (large / regenerable) — raw, inputs, and model runs stay out of git
data/

# results/ (curated figures, tables, summaries) IS tracked on purpose — do not
# ignore it. Large model scratch lives in data/urban-mental-health/runs/ instead.

# Leftover empty folders from an earlier layout (delete these manually;
# the synced drive blocks automated deletion)
/scripts/
/code/
/sf-ndvi-2024/

# Python
__pycache__/
*.py[cod]
.venv/
venv/
env/
*.egg-info/
.pytest_cache/
.ipynb_checkpoints/

# OS / editor cruft
.DS_Store
.idea/

# VS Code: share the project config, ignore personal/local settings
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json

# generated outputs
docs/results_summary.md
docs/tcc_ndvi_regression.md
figures/*.png
results/snapp_qgis.qgz
